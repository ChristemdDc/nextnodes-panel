<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>NextNodes Panel</title>
  <link rel="stylesheet" href="styles.css" />
  <link rel="stylesheet" href="auth-styles.css" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <script src="https://accounts.google.com/gsi/client" async defer></script>
</head>
<body>
  <aside class="sidebar" id="sidebar">
    <div class="sidebar-header">
      <div class="sidebar-brand">
        <span class="brand-icon">⬡</span>
      </div>
    </div>

    <nav class="sidebar-nav">
      <div class="nav-group">
        <a href="#" class="nav-link active" data-target="dashboard">
          <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 3v18"/><path d="M3 9h18"/></svg>
          <span class="nav-text">Dashboard</span>
        </a>
        <a href="#" class="nav-link" data-target="groups">
          <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          <span class="nav-text">Groups</span>
        </a>
        <a href="#" class="nav-link" data-target="users">
          <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7"/></svg>
          <span class="nav-text">Users</span>
        </a>
        <a href="#" class="nav-link" data-target="audit">
          <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
          <span class="nav-text">Audit Log</span>
        </a>
        <a href="#" class="nav-link" data-target="settings">
          <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-2 2 2 2 0 01-2-2v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83 0 2 2 0 010-2.83l.06-.06a1.65 1.65 0 00.33-1.82 1.65 1.65 0 00-1.51-1H3a2 2 0 01-2-2 2 2 0 012-2h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 010-2.83 2 2 0 012.83 0l.06.06a1.65 1.65 0 001.82.33H9a1.65 1.65 0 001-1.51V3a2 2 0 012-2 2 2 0 012 2v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 0 2 2 0 010 2.83l-.06.06a1.65 1.65 0 00-.33 1.82V9a1.65 1.65 0 001.51 1H21a2 2 0 012 2 2 2 0 01-2 2h-.09a1.65 1.65 0 00-1.51 1z"/></svg>
          <span class="nav-text">Settings</span>
        </a>
      </div>
    </nav>
    
    <div class="sidebar-bottom">
      <div class="status-info">
        <div id="serverStatus" class="mini-status offline"></div>
        <span class="nav-text" id="serverStatusText">Offline</span>
      </div>
      <button class="nav-link" id="linkServerBtn">
        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path></svg>
        <span class="nav-text">Link Server</span>
      </button>
      <button class="nav-link hidden" id="disconnectBtn">
        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18.36 6.64a9 9 0 1 1-12.73 0"></path><line x1="12" y1="2" x2="12" y2="12"></line></svg>
        <span class="nav-text">Disconnect</span>
      </button>
      <button class="sidebar-toggle" id="sidebarToggle" aria-label="Toggle sidebar">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
        <span class="toggle-text">Collapse</span>
      </button>
    </div>
  </aside>

  <main>
    <!-- Top Navigation Bar -->
    <nav class="top-navbar">
      <div class="navbar-content">
        <div class="nav-left"></div>
        
        <div class="nav-center">
          <div id="userDisplayName" class="user-status-badge hidden">
            <span class="status-dot"></span>
            <span class="status-text">Bienvenido</span>
          </div>
        </div>

        <div class="nav-right">
          <button class="btn btn-gradient" id="loginBtn">Login</button>
          <button class="btn btn-outline hidden" id="logoutBtnTop">Logout</button>
        </div>
      </div>
    </nav>

    <!-- Link Server View -->
    <section id="link-view" class="view hidden">
      <div class="link-container">
        <h1>Link Your Server</h1>
        <p>Enter the key generated by <code>/nextnodes link</code> on your Minecraft server.</p>
        <div class="link-form">
          <input type="text" id="linkKeyInput" placeholder="Enter link key..." />
          <button class="btn btn-primary" id="confirmLinkBtn">Connect</button>
        </div>
        <p id="linkMessage" class="message"></p>
      </div>
    </section>

    <!-- Dashboard View -->
    <section id="dashboard-view" class="view active">
      <div class="hero-mini">
        <h1>Server Overview</h1>
        <p>Manage your permissions in real-time.</p>
      </div>

      <div class="stats-grid">
        <div class="premium-card" id="card-users">
          <div class="card-icon-wrapper violet">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
          </div>
          <div class="card-content">
            <span class="card-label">Users</span>
            <h2 id="userCount" class="card-value">--</h2>
          </div>
        </div>
        <div class="premium-card" id="card-groups">
          <div class="card-icon-wrapper blue">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><path d="M9 12l2 2 4-4"></path></svg>
          </div>
          <div class="card-content">
            <span class="card-label">Groups</span>
            <h2 id="groupCount" class="card-value">--</h2>
          </div>
        </div>
        <div class="premium-card" id="card-status">
          <div class="card-icon-wrapper orange">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline></svg>
          </div>
          <div class="card-content">
            <span class="card-label">Status</span>
            <h2 id="uptime" class="card-value">--</h2>
          </div>
        </div>
      </div>
    </section>

    <!-- Groups View -->
    <section id="groups-view" class="view hidden">
      <div class="section-header">
        <h2>Groups</h2>
        <button class="btn btn-primary" id="createGroupBtn">New Group</button>
      </div>
      <div class="table-wrapper">
        <table class="data-table">
          <thead>
            <tr>
              <th>Name</th>
              <th>Weight</th>
              <th>Prefix</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody id="groupsTableBody"></tbody>
        </table>
      </div>
    </section>

    <!-- Users View -->
    <section id="users-view" class="view hidden">
      <div class="section-header">
        <h2>Users</h2>
        <div class="search-bar">
          <input type="text" id="userSearchInput" placeholder="Search by UUID or Name..." />
          <button class="btn btn-outline" id="searchUserBtn">Search</button>
        </div>
      </div>
      
      <!-- User List -->
      <div id="usersListContainer" style="margin-bottom: 2rem;">
        <h3>Registered Users</h3>
        <div class="table-wrapper">
          <table class="data-table">
            <thead>
              <tr>
                <th>Player</th>
                <th>Status</th>
                <th>UUID</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody id="usersTableBody"></tbody>
          </table>
        </div>
      </div>
      
      <!-- User Profile (Hidden by default) -->
      <div id="userInfoContainer" class="hidden" style="display: none; margin-top: 2rem; background: var(--bg-card); padding: 1.5rem; border-radius: var(--radius); border: 1px solid var(--border);">
          <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
              <div style="display: flex; align-items: center; gap: 1rem;">
                  <img id="userHeadDisplay" src="" alt="Player Head" style="width: 48px; height: 48px; border-radius: 4px; image-rendering: pixelated;" />
                  <div>
                      <h3 id="userNameDisplay" style="margin-bottom: 0.2rem;">--</h3>
                      <p id="userUuidDisplay" style="color: var(--text-secondary); font-family: monospace; font-size: 0.85rem;">--</p>
                  </div>
              </div>
              <button class="btn btn-outline" id="closeProfileBtn">Close Profile</button>
          </div>
          
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem;">
              <!-- User Groups -->
              <div>
                  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
                      <h4>Inherited Groups</h4>
                      <button class="btn btn-primary" id="addUserGroupBtn" style="font-size: 0.75rem; padding: 0.25rem 0.5rem;">+ Add Group</button>
                  </div>
                  <ul id="userGroupsList" style="list-style: none; padding: 0;"></ul>
              </div>
              
              <!-- User Direct Permissions -->
              <div>
                  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
                      <h4>Direct Permissions</h4>
                      <button class="btn btn-primary" id="addUserPermBtn" style="font-size: 0.75rem; padding: 0.25rem 0.5rem;">+ Add Perm</button>
                  </div>
                  <ul id="userPermsList" style="list-style: none; padding: 0;"></ul>
              </div>
          </div>

          <!-- Metadata Section -->
          <div style="margin-top: 2rem; padding-top: 2rem; border-top: 1px solid var(--border);">
              <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
                  <h4>Metadata (Prefix & Suffix)</h4>
                  <button class="btn btn-primary" id="addMetaBtn" style="font-size: 0.75rem; padding: 0.25rem 0.5rem;">+ Add Meta</button>
              </div>
              <ul id="userMetaList" style="list-style: none; padding: 0; display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1rem;"></ul>
          </div>

          <!-- Meta Modal (Hidden by default) -->
          <div id="metaModal" class="hidden" style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.7); display: flex; align-items: center; justify-content: center; z-index: 1000;">
              <div style="background: var(--bg-card); padding: 2rem; border-radius: var(--radius); border: 1px solid var(--border); width: 400px; max-width: 90%;">
                  <h3>Add Metadata</h3>
                  
                  <div class="form-group" style="margin-top: 1rem;">
                      <label>Type</label>
                      <select id="metaTypeInput" style="width: 100%; padding: 0.5rem; background: var(--bg-dark); border: 1px solid var(--border); color: var(--text-primary); border-radius: 4px;">
                          <option value="PREFIX">Prefix</option>
                          <option value="SUFFIX">Suffix</option>
                      </select>
                  </div>

                  <div class="form-group" style="margin-top: 1rem;">
                      <label>Priority (Higher overrides)</label>
                      <input type="number" id="metaPriorityInput" value="10" style="width: 100%; padding: 0.5rem; background: var(--bg-dark); border: 1px solid var(--border); color: var(--text-primary); border-radius: 4px;" />
                  </div>

                  <div class="form-group" style="margin-top: 1rem;">
                      <label>Content</label>
                      
                      <!-- Tabs for Tools -->
                      <div style="display: flex; gap: 1rem; margin-bottom: 0.5rem; border-bottom: 1px solid var(--border);">
                          <button id="tabSimpleBtn" class="btn btn-outline" style="border-bottom: none; border-radius: 4px 4px 0 0; background: var(--bg-card);">Simple Colors</button>
                          <button id="tabGradientBtn" class="btn btn-outline" style="border-bottom: none; border-radius: 4px 4px 0 0;">Gradient</button>
                      </div>

                      <!-- Simple Colors Tool -->
                      <div id="toolSimple" style="display: block;">
                          <div style="display: flex; gap: 0.5rem; margin-bottom: 0.5rem;">
                              <div style="display: flex; gap: 2px; flex-wrap: wrap; background: #222; padding: 4px; border-radius: 4px; flex: 1;">
                                  <button class="color-btn" style="background:#000000" data-code="&0" title="Black"></button>
                                  <button class="color-btn" style="background:#0000AA" data-code="&1" title="Dark Blue"></button>
                                  <button class="color-btn" style="background:#00AA00" data-code="&2" title="Dark Green"></button>
                                  <button class="color-btn" style="background:#00AAAA" data-code="&3" title="Dark Aqua"></button>
                                  <button class="color-btn" style="background:#AA0000" data-code="&4" title="Dark Red"></button>
                                  <button class="color-btn" style="background:#AA00AA" data-code="&5" title="Dark Purple"></button>
                                  <button class="color-btn" style="background:#FFAA00" data-code="&6" title="Gold"></button>
                                  <button class="color-btn" style="background:#AAAAAA" data-code="&7" title="Gray"></button>
                                  <button class="color-btn" style="background:#555555" data-code="&8" title="Dark Gray"></button>
                                  <button class="color-btn" style="background:#5555FF" data-code="&9" title="Blue"></button>
                                  <button class="color-btn" style="background:#55FF55" data-code="&a" title="Green"></button>
                                  <button class="color-btn" style="background:#55FFFF" data-code="&b" title="Aqua"></button>
                                  <button class="color-btn" style="background:#FF5555" data-code="&c" title="Red"></button>
                                  <button class="color-btn" style="background:#FF55FF" data-code="&d" title="Light Purple"></button>
                                  <button class="color-btn" style="background:#FFFF55" data-code="&e" title="Yellow"></button>
                                  <button class="color-btn" style="background:#FFFFFF; border: 1px solid #555" data-code="&f" title="White"></button>
                              </div>
                              <div style="display: flex; gap: 2px; background: #222; padding: 4px; border-radius: 4px;">
                                  <button class="format-btn" style="font-weight:bold" data-code="&l" title="Bold">B</button>
                                  <button class="format-btn" style="font-style:italic" data-code="&o" title="Italic">I</button>
                                  <button class="format-btn" style="text-decoration:underline" data-code="&n" title="Underline">U</button>
                                  <button class="format-btn" data-code="&r" title="Reset">R</button>
                              </div>
                          </div>
                      </div>

                      <!-- Multi-Stop Gradient Tool -->
                      <div id="toolGradient" class="hidden" style="margin-bottom: 1rem;">
                          <div class="grad-tool-wrapper">
                              <div class="grad-controls-row">
                                  <input type="text" id="gradText" class="grad-text-input" placeholder="Gradient text...">
                                  <button id="gradBoldBtn" class="grad-toggle-btn" title="Bold">B</button>
                                  <button id="applyGradBtn" class="grad-apply-btn">Apply</button>
                              </div>
                              <div id="gradStopsContainer" class="grad-stops-row">
                                  <button id="addGradStopBtn" class="grad-add-btn" title="Add Color">+</button>
                              </div>
                          </div>
                      </div>

                      <input type="text" id="metaContentInput" placeholder="Click colors or type & codes..." style="width: 100%; padding: 0.5rem; background: var(--bg-dark); border: 1px solid var(--border); color: var(--text-primary); border-radius: 4px;" />
                  </div>

                  <div style="margin-top: 1.5rem; padding: 1rem; background: #1a1a1a; border-radius: 4px; border: 1px solid var(--border);">
                      <label style="font-size: 0.75rem; color: var(--text-secondary); display: block; margin-bottom: 0.5rem;">Preview:</label>
                      <div id="metaPreview" style="font-family: 'Minecraft', monospace; font-size: 1.1rem;">
                          <span style="color: #aaaaaa;">(Type to preview)</span> Name
                      </div>
                  </div>

                  <div style="display: flex; justify-content: flex-end; gap: 1rem; margin-top: 2rem;">
                      <button class="btn btn-outline" id="cancelMetaBtn">Cancel</button>
                      <button class="btn btn-primary" id="saveMetaBtn">Save</button>
                  </div>
              </div>
          </div>
      </div>
    </section>

    <!-- Audit Log View -->
    <section id="audit-view" class="view hidden">
      <div class="section-header">
        <h2>Audit Log</h2>
        <button class="btn btn-outline" id="refreshAuditBtn">Refresh</button>
      </div>
      <div class="table-wrapper">
        <table class="data-table">
          <thead>
            <tr>
              <th>Time</th>
              <th>Actor</th>
              <th>Action</th>
              <th>Target</th>
              <th>Details</th>
            </tr>
          </thead>
          <tbody id="auditTableBody">
            <tr><td colspan="5" style="text-align: center; color: var(--text-secondary);">No logs loaded.</td></tr>
          </tbody>
        </table>
      </div>
    </section>

    <!-- Settings View -->
    <section id="settings-view" class="view hidden">
      <h2>Settings</h2>
      <div class="settings-form">
        <div class="form-group">
            <label>API URL</label>
            <input type="text" id="apiUrl" value="http://localhost:8081/api/v1" />
        </div>
        <button class="btn btn-primary" id="saveSettingsBtn">Save</button>
      </div>
    </section>

    <!-- Footer -->
    <footer class="footer">
      <div class="footer-content">
        <p>&copy; 2026 Lucerion. All rights reserved.</p>
        <div class="footer-links">
          <a href="#" id="privacyLink" class="footer-link">Privacy Policy</a>
          <span class="footer-separator">|</span>
          <a href="#" id="termsLink" class="footer-link">Terms & Conditions</a>
        </div>
      </div>
    </footer>

    <!-- Privacy Policy Modal -->
    <div id="privacyModal" class="modal hidden">
      <div class="modal-content">
        <div class="modal-header">
          <h2>Política de Privacidad de NextNodes</h2>
          <button class="modal-close" id="closePrivacyBtn">&times;</button>
        </div>
        <div class="modal-body">
          <h3>1. Introducción</h3>
          <p>Esta Política de Privacidad explica qué datos recopila NextNodes, cómo los utiliza, con quién puede compartirlos y qué derechos tienen los usuarios.</p>

          <h3>2. Responsable del tratamiento</h3>
          <ul>
            <li>Nombre o razón social: <strong>Lucerion</strong></li>
            <li>Correo: <strong>lucerion.studios@outlook.com</strong></li>
            <li>Domicilio o identificación legal: <strong>[Pendiente]</strong></li>
            <li>País / jurisdicción: <strong>[Pendiente]</strong></li>
          </ul>

          <h3>3. Datos que podemos recopilar</h3>
          <h4>3.1 Datos de cuenta</h4>
          <ul>
            <li>correo electrónico</li>
            <li>username o nombre visible</li>
            <li>hash de contraseña</li>
            <li>identificadores internos de cuenta</li>
          </ul>

          <h4>3.2 Datos de autenticación externa</h4>
          <p>Si el usuario inicia sesión con Google u otro proveedor, podemos recibir identificadores y datos básicos autorizados por dicho proveedor.</p>

          <h4>3.3 Datos técnicos y de seguridad</h4>
          <ul>
            <li>IP</li>
            <li>user-agent</li>
            <li>fechas y horas de acceso</li>
            <li>eventos de login, logout, bloqueos y verificaciones</li>
            <li>identificadores de sesión o datos técnicos equivalentes</li>
          </ul>

          <h4>3.4 Datos operativos</h4>
          <ul>
            <li>identificadores de servidor vinculados</li>
            <li>claves o estados de vinculación</li>
            <li>grupos, permisos, configuraciones y auditoría generada en el uso del panel</li>
          </ul>

          <h3>4. Finalidades del tratamiento</h3>
          <p>Usamos los datos para:</p>
          <ul>
            <li>crear y administrar cuentas;</li>
            <li>autenticar usuarios;</li>
            <li>verificar correos;</li>
            <li>operar el panel;</li>
            <li>vincular servidores;</li>
            <li>prevenir fraude, bots y accesos no autorizados;</li>
            <li>mantener, depurar y mejorar el servicio;</li>
            <li>cumplir obligaciones legales.</li>
          </ul>

          <h3>5. Base legal</h3>
          <p>La base legal podrá incluir ejecución contractual, interés legítimo, cumplimiento de obligaciones legales o consentimiento, según la jurisdicción aplicable.</p>

          <h3>6. Verificación y antiabuso</h3>
          <p>Podemos enviar códigos de verificación, enlaces temporales y aplicar controles de seguridad como límites de intentos, bloqueos temporales o medidas anti-bot.</p>

          <h3>7. Cookies y tecnologías similares</h3>
          <p>Podemos utilizar cookies, almacenamiento local y tecnologías similares para sesiones, seguridad, preferencias y funcionamiento del sitio.</p>

          <h3>8. Compartición de datos</h3>
          <p>Los datos podrán compartirse con proveedores de hosting, correo, autenticación, seguridad, analítica o autoridades cuando exista base legal suficiente. No vendemos datos personales.</p>

          <h3>9. Transferencias internacionales</h3>
          <p>Según la infraestructura utilizada, los datos podrán ser tratados fuera del país del usuario.</p>

          <h3>10. Conservación</h3>
          <p>Conservamos los datos durante el tiempo necesario para prestar el servicio, mantener la seguridad, cumplir obligaciones legales y resolver disputas.</p>

          <h3>11. Seguridad</h3>
          <p>Aplicamos medidas técnicas y organizativas razonables para proteger la información, aunque no puede garantizarse seguridad absoluta.</p>

          <h3>12. Derechos del usuario</h3>
          <p>Cuando corresponda legalmente, el usuario podrá solicitar acceso, rectificación, supresión, actualización, limitación, oposición o portabilidad.</p>

          <h3>13. Menores de edad</h3>
          <p>El servicio no está dirigido intencionalmente a menores sin la autorización que legalmente corresponda.</p>

          <h3>14. Terceros</h3>
          <p>El sitio puede contener integraciones o enlaces a servicios de terceros. Recomendamos revisar sus políticas.</p>

          <h3>15. Cambios a esta política</h3>
          <p>Podemos actualizar esta política en cualquier momento. La versión vigente será la publicada en el sitio.</p>

          <h3>16. Contacto</h3>
          <ul>
            <li>Responsable / titular: <strong>Lucerion</strong></li>
            <li>Correo: <strong>support@lucerion.com</strong></li>
            <li>Domicilio o identificación legal: <strong>[Pendiente]</strong></li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Terms & Conditions Modal -->
    <div id="termsModal" class="modal hidden">
      <div class="modal-content">
        <div class="modal-header">
          <h2>Términos y Condiciones de NextNodes</h2>
          <button class="modal-close" id="closeTermsBtn">&times;</button>
        </div>
        <div class="modal-body">
          <h3>1. Aceptación</h3>
          <p>Al acceder o utilizar el panel web, sitio o servicios de NextNodes, el usuario acepta estos Términos y Condiciones.</p>

          <h3>2. Descripción del servicio</h3>
          <p>NextNodes es una plataforma para administrar permisos, grupos, rangos, configuraciones, vínculos de servidor y funciones relacionadas.</p>

          <h3>3. Cuentas</h3>
          <p>El usuario debe proporcionar información veraz y mantener la confidencialidad de sus credenciales. El titular del servicio podrá suspender cuentas por abuso, fraude, automatización no autorizada o incumplimiento.</p>

          <h3>4. Verificación de correo</h3>
          <p>El servicio puede exigir validación de correo mediante código, enlace temporal u otro mecanismo equivalente.</p>

          <h3>5. Inicio de sesión con terceros</h3>
          <p>El servicio puede ofrecer autenticación mediante Google u otros proveedores. El uso de dichos proveedores también queda sujeto a sus propios términos y políticas.</p>

          <h3>6. Seguridad</h3>
          <p>El usuario debe proteger sus credenciales y notificar accesos sospechosos. El servicio puede aplicar controles como rate limiting, bloqueo temporal o reautenticación.</p>

          <h3>7. Vinculación de servidores</h3>
          <p>Las claves de vinculación o tokens de emparejamiento pueden ser de un solo uso, temporales, revocables y sujetas a medidas de seguridad adicionales.</p>

          <h3>8. Uso permitido</h3>
          <p>Se prohíbe:</p>
          <ul>
            <li>eludir autenticación o autorización;</li>
            <li>automatizar accesos sin autorización;</li>
            <li>interferir con cuentas, servidores o paneles de terceros;</li>
            <li>usar el servicio con fines ilícitos o abusivos.</li>
          </ul>

          <h3>9. Datos del usuario</h3>
          <p>El usuario conserva titularidad sobre sus datos, configuraciones y contenido, pero autoriza su tratamiento en la medida necesaria para operar el servicio.</p>

          <h3>10. Disponibilidad</h3>
          <p>El servicio podrá modificarse, interrumpirse o suspenderse por mantenimiento, seguridad, mejoras o causas técnicas.</p>

          <h3>11. Propiedad intelectual</h3>
          <p>Salvo indicación en contrario, el software, interfaz, documentación y materiales de NextNodes son propiedad de su titular o se usan bajo licencia.</p>

          <h3>12. Servicios de terceros</h3>
          <p>NextNodes puede depender de servicios externos como proveedores de correo, autenticación, hosting, repositorios o infraestructura.</p>

          <h3>13. Limitación de responsabilidad</h3>
          <p>En la máxima medida permitida por la ley, el titular no será responsable por daños indirectos, pérdida de datos, interrupciones o problemas derivados del uso del servicio.</p>

          <h3>14. Terminación</h3>
          <p>El titular podrá suspender o cancelar accesos cuando exista incumplimiento, riesgo de seguridad, fraude o abuso.</p>

          <h3>15. Privacidad</h3>
          <p>El tratamiento de datos personales se rige además por la Política de Privacidad de NextNodes.</p>

          <h3>16. Modificaciones</h3>
          <p>Estos términos pueden ser actualizados en cualquier momento. La versión vigente será la publicada en el sitio.</p>

          <h3>17. Ley aplicable y jurisdicción</h3>
          <p>Se regirán por las leyes de la jurisdicción correspondiente y cualquier controversia se someterá a los tribunales competentes.</p>

          <h3>18. Contacto</h3>
          <ul>
            <li>Responsable / titular: <strong>Lucerion</strong></li>
            <li>Correo: <strong>support@lucerion.com</strong></li>
            <li>Domicilio o identificación legal: <strong>[Pendiente]</strong></li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Custom Confirmation Modal (Logout) -->
    <div id="confirmLogoutModal" class="modal hidden" style="z-index: 3000;">
      <div class="modal-content" style="max-width: 400px; text-align: center;">
        <div class="modal-body" style="padding: 2.5rem;">
          <div style="font-size: 3rem; margin-bottom: 1rem;">🚪</div>
          <h2 style="color: var(--text-primary); margin-bottom: 0.5rem;">¿Cerrar sesión?</h2>
          <p style="color: var(--text-secondary); margin-bottom: 2rem;">Tendrás que volver a autenticarte para acceder a tu panel.</p>
          
          <div style="display: flex; gap: 1rem; justify-content: center;">
            <button id="cancelLogoutBtn" class="btn btn-outline" style="flex: 1;">Cancelar</button>
            <button id="confirmLogoutSubmitBtn" class="btn btn-primary" style="flex: 1;">Finalizar</button>
          </div>
        </div>
      </div>
    </div>

    <!-- General Information Modal (Alert Replacement) -->
    <div id="generalInfoModal" class="modal hidden" style="z-index: 4000;">
      <div class="modal-content" style="max-width: 400px; text-align: center;">
        <div class="modal-body" style="padding: 2.5rem;">
          <div id="infoModalIcon" style="font-size: 3rem; margin-bottom: 1rem;">ℹ️</div>
          <h2 id="infoModalTitle" style="color: var(--text-primary); margin-bottom: 0.5rem;">Atención</h2>
          <p id="infoModalMessage" style="color: var(--text-secondary); margin-bottom: 2rem;">Mensaje del sistema.</p>
          
          <div style="display: flex; justify-content: center;">
            <button id="closeInfoModalBtn" class="btn btn-primary" style="width: 100%;">Entendido</button>
          </div>
        </div>
      </div>
    </div>
  </main>
  
